---
import publications from '../data/publications.json';
import PaperDetail from './PaperDetail.astro';

const allPubs = publications.publications;
---

<main class="right-panel" id="right-panel">
  <!-- Beach Animation Canvas (always behind) -->
  <canvas class="beach-canvas" id="beach-canvas"></canvas>

  <!-- Detail layer — slides in over the beach, no popup -->
  <div class="detail-layer" id="detail-layer">
    <button class="btn-pill detail-back-pos" id="detail-back" aria-label="Close">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 5l-7 7 7 7"/>
      </svg>
      <span>Back</span>
    </button>
    <div class="detail-scroll" id="detail-body">
      {allPubs.map(pub => (
          <div class="paper-detail-wrap" data-detail-id={pub.id} style="display:none;">
            <PaperDetail
              paper={pub}
              detailContent={pub.description}
            />
          </div>
      ))}
    </div>
  </div>

  <!-- CV layer -->
  <div class="detail-layer" id="cv-layer">
    <button class="btn-pill detail-back-pos" id="cv-back" aria-label="Close">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 5l-7 7 7 7"/>
      </svg>
      <span>Back</span>
    </button>
    <div class="detail-scroll cv-scroll">
      <div class="cv-header">
        <h2 style="margin:0; color: var(--text);">Curriculum Vitae</h2>
        <a href="/pdf/TaeSooKim_CV.pdf" target="_blank" class="btn-outline">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
          Download PDF
        </a>
      </div>
      <iframe src="/pdf/TaeSooKim_CV.pdf" class="cv-iframe" title="CV"></iframe>
    </div>
  </div>

  <!-- Prefers-reduced-motion fallback -->
  <div class="beach-static-fallback" id="beach-fallback"></div>
</main>

<style>
  .beach-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    image-rendering: pixelated;
    z-index: 1;
    transition: opacity 0.5s ease, filter 0.5s ease;
    opacity: 0.3;
  }
  .beach-canvas.dimmed {
    opacity: 0.15;
    filter: brightness(0.85) saturate(0.7);
  }

  .beach-static-fallback {
    display: none;
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      #F2F4F6 0%,
      #E5E7EB 20%,
      #D1D5DB 40%,
      #9CA3AF 60%,
      #D1D5DB 80%,
      #E5E7EB 100%
    );
    z-index: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .beach-canvas { display: none; }
    .beach-static-fallback { display: block; }
  }

  /* ── Detail Layer — inline, full right panel ── */
  .detail-layer {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 5;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(12px);
    pointer-events: none;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .detail-layer.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* Desktop: Offset to accommodate Left Panel */
  @media (min-width: 769px) {
    .detail-layer {
      left: clamp(var(--left-panel-min), var(--left-panel-w), var(--left-panel-max));
    }
  }

  .detail-back-pos {
    position: absolute;
    top: 24px;
    left: 24px;
    z-index: 6;
  }

  .detail-scroll {
    flex: 1;
    overflow-y: auto;
    padding: 72px 48px 48px;
    scrollbar-width: thin;
    scrollbar-color: var(--sand) transparent;
  }
  .detail-scroll::-webkit-scrollbar { width: 5px; }
  .detail-scroll::-webkit-scrollbar-thumb { background: var(--sand); border-radius: 3px; }

  /* CV specific */
  .cv-scroll { display: flex; flex-direction: column; }
  .cv-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }
  .cv-iframe {
    flex: 1;
    width: 100%;
    min-height: 600px;
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    background: var(--bg-surface);
  }

  /* ── Paper Detail Styles ── */
  :global(.paper-detail) {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 620px;
  }
  :global(.paper-detail-title) {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--text);
  }
  :global(.paper-detail-meta) {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  :global(.paper-detail-venue) {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent);
  }
  :global(.paper-detail-award) {
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--award-gold);
  }

  :global(.paper-detail-teaser-wrap) {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--card-border);
    background: var(--bg-surface);
  }
  :global(.paper-detail-teaser) {
    width: 100%;
    display: block;
    filter: contrast(1.02) brightness(1);
  }

  :global(.paper-detail-authors) {
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--text-muted);
  }
  :global(.paper-detail-description) {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--text);
  }
  :global(.paper-detail-description p) {
    margin-bottom: 12px;
  }
  :global(.paper-detail-description p:last-child) {
    margin-bottom: 0;
  }
  :global(.paper-detail-description strong) {
    color: var(--accent);
    font-weight: 600;
  }
  :global(.paper-detail-links) {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  @media (max-width: 768px) {
    .detail-scroll { padding: 64px 24px 32px; }
    .detail-back-pos { top: 16px; left: 16px; }
  }
</style>
